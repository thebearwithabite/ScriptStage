# ScriptStage Environment Configuration
# Copy this file to .env and customize for your setup.
# The .env file is ignored by Git, so your local IPs and usernames stay private.

# ==============================================================================
# TTS Server Configuration (Client Side)
# ==============================================================================
# The URL where your Mac will send TTS requests.
# If running locally, this would be http://127.0.0.1:8000
# For your RTX 5090 via Tailscale, set this to your WSL Tailscale IP:
TTS_SERVER_URL="http://100.103.210.101:8000"

# Optional: Commands to automatically start and stop the server over SSH
# This allows the Mac client to spin up the 5090 server before generating,
# and spin it down afterward to free up VRAM for ComfyUI/WanGP.
#
# Example (adjust paths and conda environment to match your WSL setup):
# TTS_SSH_START_CMD="ssh -p 2222 bear@100.103.210.101 'source ~/miniconda3/bin/activate qwen3-tts && nohup python ~/tts_server.py > ~/tts_server.log 2>&1 & echo \$!'"
# TTS_SSH_STOP_CMD="ssh -p 2222 bear@100.103.210.101 'pkill -f tts_server.py'"
